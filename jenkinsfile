//pipeline declaration
pipeline{

    //agent definition
    agent any


    environment {
        IMAGE_NAME = "flask-app"
    }

    stages{
        stage('checkout'){
            steps{
                checkout scm
            }
        }
        stage('Build') {
            steps {
                sh "docker build -t ${IMAGE_NAME} ."
            }
        }

        stage('Test') {
            steps {
                sh 'echo Running tests'
                //sh 'pip install -r requirements.txt'
                //sh 'pytest'
            }
        }

        stage('Run Container') {
            steps {
                sh "docker run -d -p 5000:5000 ${IMAGE_NAME}"
            }
        }

    }
}